# LLM Provider — "groq" (free) or "anthropic"
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
POSTGRES_USER=automl
POSTGRES_PASSWORD=automl
POSTGRES_DB=automl
DATABASE_URL=postgresql+asyncpg://automl:automl@postgres:5432/automl
DATABASE_URL_SYNC=postgresql://automl:automl@postgres:5432/automl

# Redis
REDIS_URL=redis://redis:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Sandbox
SANDBOX_URL=http://sandbox:8001

# Storage (shared volume mounted at /data in both backend and sandbox)
DATA_DIR=/data

# App
DEBUG=false
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
GIT_PYTHON_REFRESH=quiet
